{
  "name": "thothfilter",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "build/Release",
    "src",
    "binding.gyp"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc",
    "build:debug": "node-gyp rebuild --debug",
    "clean": "node-gyp clean && rimraf dist",
    "dev": "npm run build && nodemon dist/index.js",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "bench": "npm run build && node --expose-gc --experimental-strip-types bench/index.ts",
    "bench:compare": "npm run build && BENCH_COMPARE=1 node --expose-gc --experimental-strip-types bench/index.ts",
    "bench:sweep": "npm run build && node --expose-gc --experimental-strip-types bench/sweep.ts",
    "bench:fp": "npm run build && node --expose-gc --experimental-strip-types bench/fp.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "npm run build:ts && tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:cc": "find . -name \"*.cc\" -exec clang-format -i {} \\;",
    "format": "find . \\( -name \"*.cc\" -o -name \"*.cpp\" -o -name \"*.h\" \\) -exec clang-format -i {} \\;",
    "docs": "typedoc",
    "changelog": "git-cliff -o CHANGELOG.md",
    "prepare": "lefthook install"
  },
  "gypfile": true,
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/cli": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "eslint": "^10.5.0",
    "git-cliff": "^2.10.1",
    "jest": "^30.4.2",
    "lefthook": "^2.1.9",
    "node-api-headers": "^1.9.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "node-addon-api": "^8.8.0"
  }
}

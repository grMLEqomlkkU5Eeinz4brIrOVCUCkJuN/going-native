# Publishing is driven by the "files" allowlist in package.json (dist,
# build/Release, src, binding.gyp), so this file is just a backstop to keep
# development-only tooling out of the published tarball.
/docs
/lib
/.vscode
/.github
eslint.config.js
tsconfig.json
tsconfig.test.json
jest.config.js
/test
/bench
typedoc.json
cliff.toml
lefthook.yml
commitlint.config.js
release.sh
.clang-format
.clangd
.nvmrc
INTERNAL/

# Build outputs
dist/
build/
*.node

# Generated API docs (TypeDoc). The hand-written guides in docs/*.md are
# committed; only the generated reference under docs/api/ is ignored.
docs/api/

# Tooling caches / packs
.eslintcache
*.tgz

# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Environment
.env
.env.*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
